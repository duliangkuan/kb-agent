# ===== 硅基流动 SiliconFlow（embedding / reranker / 大模型流式生成，必填）=====
SILICONFLOW_API_KEY=sk-你的硅基流动key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LLM_MODEL=deepseek-ai/DeepSeek-V3

# ===== TextIn 通用文档解析（上传 PDF/图片/复杂文档时使用，可选）=====
# 不填则只支持「直接输入文本」和「上传 txt」两种入库方式
TEXTIN_APP_ID=你的textin_app_id
TEXTIN_SECRET_CODE=你的textin_secret_code
TEXTIN_API_URL=https://api.textin.com/ai/service/v1/pdf_to_markdown

# ===== 检索参数 =====
CHUNK_MAX_CHARS=400
CHUNK_OVERLAP=80
TOP_K_RETRIEVE=10
TOP_K_RERANK=3
SIM_THRESHOLD=0.3
USE_RERANKER=true
REQUEST_TIMEOUT=30

# ===== 存储 =====
# DB_PATH=data/kb.db
